{
  "name": "repograph-vscode",
  "displayName": "RepoGraph Protocol",
  "description": "Read-only module tree and architecture violations from .repograph/generated/graph.json",
  "version": "0.5.0",
  "private": true,
  "publisher": "repographprotocol",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/baasith6/RepoGraph-Protocol.git",
    "directory": "apps/vscode"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": [
    "workspaceContains:.repograph/project.yml"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "views": {
      "explorer": [
        {
          "id": "repographModules",
          "name": "RepoGraph Modules"
        },
        {
          "id": "repographViolations",
          "name": "RepoGraph Violations"
        }
      ]
    },
    "commands": [
      {
        "command": "repograph.refresh",
        "title": "RepoGraph: Refresh Views"
      },
      {
        "command": "repograph.openGraph",
        "title": "RepoGraph: Open graph.json"
      },
      {
        "command": "repograph.copyTaskPrompt",
        "title": "RepoGraph: Copy Task Prompt"
      }
    ]
  },
  "scripts": {
    "build": "tsc",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@repograph/context-engine": "workspace:*",
    "@repograph/exporter-markdown": "workspace:*",
    "@repograph/graph-core": "workspace:*",
    "@repograph/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.7.2"
  }
}
