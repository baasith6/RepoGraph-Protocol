{
  "name": "@repograph/mcp-server",
  "version": "0.5.0",
  "description": "MCP server exposing RepoGraph graph, explain, impact, and violations",
  "type": "module",
  "bin": {
    "repograph-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": ["dist"],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
