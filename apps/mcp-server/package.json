    "@repograph/rule-engine": "workspace:*",
    "@repograph/scanner-core": "workspace:*",
    "@repograph/shared": "workspace:*",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2"
  }
