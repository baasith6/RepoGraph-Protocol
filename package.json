{
  "name": "repograph",
  "version": "0.1.0",
  "private": true,
  "description": "Machine-readable context for human and AI developers",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "build:cli-bundle": "node scripts/bundle-cli.mjs",
    "test": "vitest run",
    "lint": "turbo run lint",
    "repograph": "node apps/cli/dist/index.js",
    "dev": "pnpm --filter @repographprotocol/cli dev",
    "publish:cli": "node scripts/publish-cli.mjs"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "esbuild": "^0.24.0",
    "turbo": "^2.3.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "packageManager": "pnpm@9.15.0"
}
