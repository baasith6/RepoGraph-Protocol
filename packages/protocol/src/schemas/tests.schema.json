{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "tests.schema.json",
  "type": "object",
  "properties": {
    "tests": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["module", "paths"],
        "properties": {
          "module": { "type": "string" },
          "paths": {
            "type": "array",
            "items": { "type": "string" }
          },
          "description": { "type": "string" }
        }
      }
    }
  }
}
