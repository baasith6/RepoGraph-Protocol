{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "rules.schema.json",
  "type": "object",
  "properties": {
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "description"],
        "properties": {
          "id": { "type": "string" },
          "description": { "type": "string" },
          "severity": {
            "type": "string",
            "enum": ["warning", "error", "critical"]
          },
          "type": { "type": "string" },
          "from": { "type": "string" },
          "to": { "type": "string" },
          "forbidden": { "type": "boolean" }
        }
      }
    },
    "enforcement": {
      "type": "object",
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["warning", "error", "strict"]
        }
      }
    }
  }
}
