{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "glossary.schema.json",
  "type": "object",
  "properties": {
    "glossary": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["term", "definition"],
        "properties": {
          "term": { "type": "string" },
          "definition": { "type": "string" },
          "module": { "type": "string" }
        }
      }
    }
  }
}
