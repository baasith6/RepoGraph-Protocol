{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "architecture.schema.json",
  "type": "object",
  "required": ["architecture", "layers"],
  "properties": {
    "architecture": {
      "type": "object",
      "properties": {
        "style": { "type": "string" }
      }
    },
    "layers": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["path"],
        "properties": {
          "path": { "type": "string" },
          "allowed_dependencies": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "description"],
        "properties": {
          "id": { "type": "string" },
          "description": { "type": "string" },
          "severity": {
            "type": "string",
            "enum": ["warning", "error", "critical"]
          }
        }
      }
    }
  }
}
