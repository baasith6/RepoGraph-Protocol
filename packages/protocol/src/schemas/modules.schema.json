{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "modules.schema.json",
  "type": "object",
  "required": ["modules"],
  "properties": {
    "modules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "paths"],
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "paths": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1
          },
          "critical": { "type": "boolean" }
        }
      }
    }
  }
}
