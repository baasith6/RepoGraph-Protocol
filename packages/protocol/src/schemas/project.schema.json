{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "project.schema.json",
  "type": "object",
  "required": ["protocol", "project"],
  "properties": {
    "protocol": {
      "type": "object",
      "required": ["name", "version"],
      "properties": {
        "name": { "type": "string", "const": "RepoGraph" },
        "version": { "type": "string", "pattern": "^0\\.1\\.\\d+$" }
      }
    },
    "project": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "type": { "type": "string" },
        "architecture": { "type": "string" },
        "primary_language": { "type": "string" },
        "secondary_languages": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "repository": {
      "type": "object",
      "properties": {
        "provider": { "type": "string" },
        "default_branch": { "type": "string" }
      }
    }
  }
}
