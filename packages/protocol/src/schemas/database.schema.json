{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "database.schema.json",
  "type": "object",
  "properties": {
    "database": {
      "type": "object",
      "properties": {
        "provider": { "type": "string" },
        "entities": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "module"],
            "properties": {
              "name": { "type": "string" },
              "module": { "type": "string" },
              "table": { "type": "string" },
              "db_context": { "type": "string" },
              "tenant_scoped": { "type": "boolean" },
              "required_fields": {
                "type": "array",
                "items": { "type": "string" }
              },
              "migration_files": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}
